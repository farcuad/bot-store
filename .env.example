# ─── WhatsApp / DeepSeek ───────────────────────────────────────────────────────
DEEPSEEK_API_KEY=

# Número de teléfono del bot (sin + ni espacios). Actúa como scope en Firestore.
# Ejemplo: 584268691664
BOT_PHONE_NUMBER=

# ─── Firebase Admin SDK ────────────────────────────────────────────────────────
# Obtén estos valores desde Firebase Console →
#   Ajustes del Proyecto > Cuentas de servicio > Generar nueva clave privada
# Copia los campos del JSON descargado aquí (NO subas el JSON al repo).
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# ─── Configuración heredada (sin uso activo) ───────────────────────────────────
PHONE_NUMBER_ID=
PHONE_ADVANCED=
FB_TOKEN=
PORT=
WEBHOOK_TOKEN=